# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep the example, ignore the secret
.env.local
.env.*.local
# .env.example is committed intentionally

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# testing
playwright-report/
test-results/

# personal audio files (added manually, not committed)
# public/audio/score/*.mp3
# public/audio/ambient/*.mp3
# public/images/photographs/
